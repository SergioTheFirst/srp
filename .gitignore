# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Lint / type / test / coverage caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- CodeGraph semantic index (regenerable; do not commit) ---
.codegraph/

# --- Packaging / build ---
build/
dist/
*.egg-info/
*.egg

# --- SRP runtime artifacts (generated; must never be committed) ---
# SQLite store the server creates at runtime
srp.db
srp.db-journal
srp.db-wal
srp.db-shm
# Agent offline spool
buffer.jsonl
# DPAPI-encrypted netdisco SNMP credential store (machine-bound secret; never commit)
server/netdisco_secrets.json
netdisco_secrets.json
client/buffer.jsonl
# Tray status snapshot + print counters (written by the running agent)
status.json
client/status.json
print_state.json
client/print_state.json
# Agent / installer run logs (generated; scoped to known names, not all *.log)
agent.log
srp-agent.log
tray.log
install.log
# Local helpers left behind by manual E2E runs
.srv.pid
client/config.json.bak

# NOTE: server/config.json and client/config.json are tracked TEMPLATES and are
# intentionally NOT ignored. The shipped client/config.json keeps device_id ""
# (the real MachineGuid is resolved at runtime and must stay out of git).

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*~

# --- OS cruft ---
Thumbs.db
desktop.ini
.DS_Store
